 67. timer off 5
 68. if _rc==1 exit 1
 69. if _rc==0 {
 70.         local method 2SN_REML
 71.         local b`method' = r(eff)
 72.         local s`method' = r(se_eff)
 73.         local tau`method' = sqrt(r(tausq))
 74.         local error`method' = 0
 75. }
 76. 
. * RE Method 6: 2-stage Normal, ML
. timer on 6
 77. cap metan b se, nograph model(ml)
 78. timer off 6
 79. if _rc==1 exit 1
 80. if _rc==0 {
 81.         local method 2SN_ML
 82.         local b`method' = r(eff)
 83.         local s`method' = r(se_eff)
 84.         local tau`method' = sqrt(r(tausq))
 85.         local error`method' = 0
 86. }
 87. 
. * RE method 7: 2-stage Poisson, unweighted
. timer on 7
