. /*
> Simulation study to evaluate two-stage Poisson (2SP) method for meta-analysis of TTE data
> Simulation definition program (see twoSPsimrun for the main program)
> Part 2: change analysis only to include more one-stage models:
>         Cox CE with interaction (1SCinter)
>         Weibull CE (1SWei)
>         Weibull RE (1SWei_ML)
>         Weibull RE + centred trt (1SWei_MLc)
> IW 25feb2026
> */
. cap program drop twoSPsimgen

. cap program drop twoSPsimana2

. 
. program define twoSPsimgen, rclass
  1. 
. // FOR SIMRUN
. local inputs studies nobslow nobsupp px aratio gamma bx beta tau cens
  2. if "`0'"=="?" {
  3.         return local inputs `inputs'
  4.         exit
  5. }
  6. 
. // GENERATE THE DATA
. version 14
  7. syntax, studies(int) nobslow(int) nobsupp(int) px(real) aratio(real) gamma(real) bx(real) beta(real) tau(real) cens(re
> al)
  8. assert `studies'>1
  9. assert inrange(`px',0,1)
 10. assert `aratio'>0
 11. clear
 12. qui set obs `studies'
 13. gen study = _n
 14. gen nobs = runiformint(`nobslow',`nobsupp')
 15. gen bz = rnormal(`beta',`tau')
 16. qui expand nobs
 17. drop nobs
 18. sort study
 19. by study: gen id = _n
 20. gen x = runiform()<`px'
 21. gen z = runiform()>1/(1+`aratio')
 22. gen t = -log(runiform())/exp(`gamma'+`bx'*x+bz*z)
 23. gen d = t<=`cens'
 24. qui replace t = `cens' if !d
 25. drop bz
 26. stset t, failure(d)
 27. 
. * Form 2-stage data
. byvar study, b(z) se(z) generate unique: stcox z x
 28. rename Bz_ b
 29. rename Sz_ se
 30. assert mi(b)==(id>1)
 31. egen d1 = sum(d*z), by(study)
 32. egen d0 = sum(d*(1-z)), by(study)
 33. egen p1 = sum(t*z), by(study)
 34. egen p0 = sum(t*(1-z)), by(study)
 35. foreach var of varlist d? p? {
 36.         qui replace `var' = . if id>1
 37. }
 38. * handle single-zero studies
. qui replace b = ln(d1+.5)-ln(p1)-ln(d0+.5)+ln(p0) if min(d0,d1)==0 
 39. qui replace se = sqrt( 1/(d1+.5) + 1/(d0+.5) )    if min(d0,d1)==0
 40. * handle double-zero studies
. qui replace b = . if max(d0,d1)==0
 41. qui replace se = . if max(d0,d1)==0
 42. 
. end

. 
. /************** end of twoSPsimgen ******************/
. 
. /************** start of twoSPsimana ******************/
. 
. prog def twoSPsimana2, rclass
  1. 
. * descriptive outputs
. local outputs n d singlezeroes doublezeroes sdb sdbw
  2. * analysis outputs
. foreach method in 1SC 1SCinter 1SWei 1SWei_ML 1SWei_MLc {
  3.         local outputs `outputs' b`method' s`method' tau`method' error`method' 
  4. }
  5. if "`0'"=="?" {
  6.         return local outputs `outputs'
  7.         exit
  8. }
  9. 
. // DESCRIPTIVE STATISTICS
. sum d, meanonly
 10. local n=r(N)
 11. local d=r(sum)
 12. qui count if d0==0 & d1==0 & id==1
 13. local doublezeroes = r(N)
 14. qui count if (d0==0 | d1==0) & id==1
 15. local singlezeroes = r(N)-`doublezeroes'
 16. * var(b)
. qui sum b
 17. local sdb = r(sd)
 18. qui sum b [w=1/se^2]
 19. local sdbw = r(sd)
 20. 
. // ANALYSE THE DATA
. * Method 1: one-stage Cox
. timer on 1
 21. cap stcox z x, strata(study)
 22. timer off 1
 23. if _rc==1 exit 1
 24. if _rc==0 {
 25.         local method 1SC
 26.         local b`method' = _b[z]
 27.         local s`method' = _se[z]
 28.         local tau`method' = 0
 29.         local error`method' = !e(converged)
 30. }
 31. 
. * Method 11: one-stage Cox with interaction
. timer on 11
 32. cap stcox z i.study##x, strata(study)
 33. timer off 11
 34. if _rc==1 exit 1
 35. if _rc==0 {
 36.         local method 1SCinter
 37.         local b`method' = _b[z]
 38.         local s`method' = _se[z]
 39.         local tau`method' = 0
 40.         local error`method' = !e(converged)
 41. }
 42. 
. * Method 12: one-stage Weibull
. timer on 12
 43. cap streg z x, strata(study) dist(weibull)
 44. timer off 12
 45. if _rc==1 exit 1
 46. if _rc==0 {
 47.         local method 1SWei
 48.         local b`method' = _b[z]
 49.         local s`method' = _se[z]
 50.         local tau`method' = 0
 51.         local error`method' = !e(converged)
 52. }
 53. 
. * Method 13: one-stage Weibull with RE
. timer on 13
 54. cap mestreg z x i.study || study:z, nocons dist(weibull)
 55. timer off 13
 56. if _rc==1 exit 1
 57. if _rc==0 {
 58.         local method 1SWei_ML
 59.         local b`method' = _b[z]
 60.         local s`method' = _se[z]
 61.         local tau`method' = sqrt(_b[/var(z[study])])
 62.         local error`method' = !e(converged)
 63. }
 64. 
. * Method 14: one-stage Weibull with RE, treatment centred
. timer on 14
 65. summ z, meanonly
 66. gen cz = z - r(mean)
 67. cap mestreg cz x i.study || study:cz, nocons dist(weibull)
 68. timer off 14
 69. if _rc==1 exit 1
 70. if _rc==0 {
 71.         local method 1SWei_MLc
 72.         local b`method' = _b[cz]
 73.         local s`method' = _se[cz]
 74.         local tau`method' = sqrt(_b[/var(cz[study])])
 75.         local error`method' = !e(converged)
 76. }
 77. 
. foreach output of local outputs {
 78.         if !mi("``output''") return scalar `output' = ``output''
 79.         else return scalar `output' = .
 80. }
 81. 
. end

. 
. /************** end of twoSPsimana ******************/
. 
. 
end of do-file

. 
