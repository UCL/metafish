. /*
> Simulation study to evaluate two-stage Poisson (2SP) method for meta-analysis of TT
> E data
> Simulation definition program (see twoSPsimrun for the main program)
> IW 10sep2025
> v0.2 IW 17sep2025
> 19sep2025: 1SC now stratifies, not adjusts (faster)
> 1oct2025: two programs, for revised simrun
> */
. cap program drop twoSPsimgen

. cap program drop twoSPsimana

. 
. program define twoSPsimgen, rclass
  1. 
. // FOR SIMRUN
. local inputs studies nobslow nobsupp px aratio gamma bx beta tau cens
  2. if "`0'"=="?" {
  3.         return local inputs `inputs'
  4.         exit
  5. }
  6. 
. // GENERATE THE DATA
. version 14
  7. syntax, studies(int) nobslow(int) nobsupp(int) px(real) aratio(real) gamma(real)
>  bx(real) beta(real) tau(real) cens(real)
  8. assert `studies'>1
  9. assert inrange(`px',0,1)
 10. assert `aratio'>0
 11. clear
 12. qui set obs `studies'
 13. gen study = _n
 14. gen nobs = runiformint(`nobslow',`nobsupp')
 15. gen bz = rnormal(`beta',`tau')
 16. qui expand nobs
 17. drop nobs
 18. sort study
 19. by study: gen id = _n
 20. gen x = runiform()<`px'
 21. gen z = runiform()>1/(1+`aratio')
 22. gen t = -log(runiform())/exp(`gamma'+`bx'*x+bz*z)
 23. gen d = t<=`cens'
 24. qui replace t = `cens' if !d
 25. drop bz
 26. stset t, failure(d)
 27. 
. * Form 2-stage data
. byvar study, b(z) se(z) generate unique: stcox z x
 28. rename Bz_ b
 29. rename Sz_ se
 30. assert mi(b)==(id>1)
 31. egen d1 = sum(d*z), by(study)
 32. egen d0 = sum(d*(1-z)), by(study)
 33. egen p1 = sum(t*z), by(study)
 34. egen p0 = sum(t*(1-z)), by(study)
 35. foreach var of varlist d? p? {
 36.         qui replace `var' = . if id>1
 37. }
 38. * handle single-zero studies
. qui replace b = ln(d1+.5)-ln(p1)-ln(d0+.5)+ln(p0) if min(d0,d1)==0 
 39. qui replace se = sqrt( 1/(d1+.5) + 1/(d0+.5) )    if min(d0,d1)==0
 40. * handle double-zero studies
. qui replace b = . if max(d0,d1)==0
 41. qui replace se = . if max(d0,d1)==0
 42. 
. end

. 
. /************** end of twoSPsimgen ******************/
. 
. /************** start of twoSPsimana ******************/
. 
. prog def twoSPsimana, rclass
  1. 
. * descriptive outputs
. local outputs n d singlezeroes doublezeroes sdb sdbw
  2. * analysis outputs
. foreach method in 1SC 2SN 2SPU 2SPW 2SN_REML 2SN_ML 2SPU_ML 2SPW_ML 2SPU_MLc 2SPW_M
> Lc {
  3.         local outputs `outputs' b`method' s`method' tau`method' error`method' 
  4. }
  5. if "`0'"=="?" {
  6.         return local outputs `outputs'
  7.         exit
  8. }
  9. 
. // DESCRIPTIVE STATISTICS
. sum d, meanonly
 10. local n=r(N)
 11. local d=r(sum)
 12. qui count if d0==0 & d1==0 & id==1
 13. local doublezeroes = r(N)
 14. qui count if (d0==0 | d1==0) & id==1
 15. local singlezeroes = r(N)-`doublezeroes'
 16. * var(b)
. qui sum b
 17. local sdb = r(sd)
 18. qui sum b [w=1/se^2]
 19. local sdbw = r(sd)
 20. 
. // ANALYSE THE DATA
. * Method 1: one-stage Cox
. timer on 1
 21. cap stcox z x, strata(study)
 22. timer off 1
 23. if _rc==1 exit 1
 24. if _rc==0 {
 25.         local method 1SC
 26.         local b`method' = _b[z]
 27.         local s`method' = _se[z]
 28.         local tau`method' = 0
 29.         local error`method' = !e(converged)
 30. }
 31. 
. * reduce to two-stage data
. keep if id==1
 32. 
. * CE Method 2: 2-stage Normal
. timer on 2
 33. cap metan b se, nograph model(iv)
 34. timer off 2
 35. if _rc==1 exit 1
 36. if _rc==0 {
 37.         local method 2SN
 38.         local b`method' = r(eff)
 39.         local s`method' = r(se_eff)
 40.         local tau`method' = 0
 41.         local error`method' = 0
 42. }
 43. 
. * CE method 3: 2-stage Poisson, unweighted
. timer on 3
 44. cap metafish b se, d(d1 d0) py(p1 p0) study(study)
 45. timer off 3
 46. if _rc==1 exit 1
 47. if _rc==0 {
 48.         local method 2SPU
 49.         local b`method' = r(eff)
 50.         local s`method' = r(se_eff)
 51.         local tau`method' = 0
 52.         local error`method' = r(error)
 53. }
 54. 
. * CE method 4: 2-stage Poisson, weighted
. timer on 4
 55. cap metafish b se, d(d1 d0) py(p1 p0) study(study) wt
 56. timer off 4
 57. if _rc==1 exit 1
 58. if _rc==0 {
 59.         local method 2SPW
 60.         local b`method' = r(eff)
 61.         local s`method' = r(se_eff)
 62.         local tau`method' = 0
 63.         local error`method' = r(error)
 64. }
 65. 
. * RE Method 5: 2-stage Normal, REML
. timer on 5
 66. cap metan b se, nograph model(reml)
 67. timer off 5
 68. if _rc==1 exit 1
 69. if _rc==0 {
 70.         local method 2SN_REML
 71.         local b`method' = r(eff)
 72.         local s`method' = r(se_eff)
 73.         local tau`method' = sqrt(r(tausq))
 74.         local error`method' = 0
 75. }
 76. 
. * RE Method 6: 2-stage Normal, ML
. timer on 6
 77. cap metan b se, nograph model(ml)
 78. timer off 6
 79. if _rc==1 exit 1
 80. if _rc==0 {
 81.         local method 2SN_ML
 82.         local b`method' = r(eff)
 83.         local s`method' = r(se_eff)
 84.         local tau`method' = sqrt(r(tausq))
 85.         local error`method' = 0
 86. }
 87. 
. * RE method 7: 2-stage Poisson, unweighted
. timer on 7
 88. cap metafish b se, d(d1 d0) py(p1 p0) study(study) re 
 89. timer off 7
 90. if _rc==1 exit 1
 91. if _rc==0 {
 92.         local method 2SPU_ML
 93.         local b`method' = r(eff)
 94.         local s`method' = r(se_eff)
 95.         local tau`method' = sqrt(r(tausq))
 96.         local error`method' = r(error)
 97. }
 98. 
. * RE method 8: 2-stage Poisson, weighted
. timer on 8
 99. cap metafish b se, d(d1 d0) py(p1 p0) study(study) re wt
100. timer off 8
101. if _rc==1 exit 1
102. if _rc==0 {
103.         local method 2SPW_ML
104.         local b`method' = r(eff)
105.         local s`method' = r(se_eff)
106.         local tau`method' = sqrt(r(tausq))
107.         local error`method' = r(error)
108. }
109. 
. * RE method 9: 2-stage Poisson, unweighted, centred
. timer on 9
110. cap metafish b se, d(d1 d0) py(p1 p0) study(study) re centre
111. timer off 9
112. if _rc==1 exit 1
113. if _rc==0 {
114.         local method 2SPU_MLc
115.         local b`method' = r(eff)
116.         local s`method' = r(se_eff)
117.         local tau`method' = sqrt(r(tausq))
118.         local error`method' = r(error)
119. }
120. 
. * RE method 10: 2-stage Poisson, weighted, centred
. timer on 10
121. cap metafish b se, d(d1 d0) py(p1 p0) study(study) re wt centre
122. timer off 10
123. if _rc==1 exit 1
124. if _rc==0 {
125.         local method 2SPW_MLc
126.         local b`method' = r(eff)
127.         local s`method' = r(se_eff)
128.         local tau`method' = sqrt(r(tausq))
129.         local error`method' = r(error)
130. }
131. 
. foreach output of local outputs {
132.         if !mi("``output''") return scalar `output' = ``output''
133.         else return scalar `output' = .
134. }
135. 
. end

. 
. /************** end of twoSPsimana ******************/
. 
. 
end of do-file

